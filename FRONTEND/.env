VITE_GOOGLE_CLIENT_ID=86427154436-bshl4enqhqf5mg0g3rpsm9qrdls1fceh.apps.googleusercontent.com

# Talk to the API directly (avoids Vite proxy 404 if proxy fails). Backend must be running on port 5000.
VITE_API_URL=http://127.0.0.1:5000

# Match backend USE_DEFAULT_USER — hide Log out; host acts as default user without login.
VITE_USE_DEFAULT_USER=true
# Must match BACKEND DEFAULT_USER_ID / email if /api/me fails (stub user for UI).
VITE_DEFAULT_USER_ID=1
VITE_DEFAULT_USER_EMAIL=demo@calendly.local